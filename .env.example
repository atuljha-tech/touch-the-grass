# Required — AI scoring, feedback, and project brief generation
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Recommended — raises GitHub API rate limit from 60 to 5000 req/hr
# Get at: https://github.com/settings/tokens (needs public_repo scope)
GITHUB_TOKEN=your_github_token_here

# Optional — connects to live Zynd agent network
# Works in demo mode without this key
# Get at: https://zynd.ai
ZYND_API_KEY=your_zynd_api_key_here

# Optional — enables full Apify Actor-based repo scraping
# Falls back to GitHub API without this key
# Get at: https://console.apify.com
APIFY_API_TOKEN=your_apify_token_here
